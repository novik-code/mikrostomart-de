---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site';
import { categoryMeta, formatDate, readingTime, slugify } from '../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const cat = categoryMeta[post.data.category];
const mins = readingTime(post.body ?? '');

const related = (() => {
  const others = allPosts.filter((p) => p.id !== post.id);
  const sameCategory = others.filter((p) => p.data.category === post.data.category);
  const sameTag = others.filter(
    (p) => p.data.category !== post.data.category && p.data.tags.some((t) => post.data.tags.includes(t)),
  );
  return [...sameCategory, ...sameTag]
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
})();

const url = new URL(`/blog/${post.id}`, site.url).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalScholarlyArticle',
  '@id': `${url}#article`,
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  inLanguage: 'de-DE',
  author: { '@id': site.author.canonicalId },
  publisher: { '@id': site.author.canonicalId },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  keywords: post.data.tags.join(', '),
  articleSection: cat.label,
  wordCount: (post.body ?? '').trim().split(/\s+/).length,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site.url}/blog` },
    { '@type': 'ListItem', position: 3, name: cat.label, item: `${site.url}/blog/kategorie/${post.data.category}` },
    { '@type': 'ListItem', position: 4, name: post.data.title },
  ],
};
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="container post">
    <nav class="breadcrumbs" aria-label="breadcrumbs">
      <a href="/">Start</a> · <a href="/blog">Blog</a> ·
      <a href={`/blog/kategorie/${post.data.category}`}>{cat.label}</a> ·
      <span class="current">{post.data.title}</span>
    </nav>

    <header>
      <p class="post-meta">
        <a class="category" href={`/blog/kategorie/${post.data.category}`}>{cat.label}</a>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span class="reading-time">· {mins} Min. Lesezeit</span>
      </p>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.description}</p>
      <aside class="author-card">
        <div>
          <strong>Behandelnder Zahnarzt: {site.author.honorificPrefix} {site.author.name}, {site.author.honorificSuffix}</strong>
          <p>M.Sc. RWTH Aachen · <a href={site.author.canonicalUrl} rel="noopener">nowosielski.pl</a> · <a href="/ueber-uns">mehr →</a></p>
        </div>
      </aside>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="tags">
        {post.data.tags.map((tag) => (
          <a class="tag" href={`/blog/tag/${slugify(tag)}`}>#{tag}</a>
        ))}
      </div>

      {related.length > 0 && (
        <section class="related">
          <h2>Weitere empfohlene Artikel</h2>
          <ul>
            {related.map((p) => (
              <li>
                <article>
                  <p class="related-meta">
                    <span class="category">{categoryMeta[p.data.category].label}</span>
                    <time datetime={p.data.pubDate.toISOString()}>{formatDate(p.data.pubDate)}</time>
                  </p>
                  <h3><a href={`/blog/${p.id}`}>{p.data.title}</a></h3>
                  <p>{p.data.description}</p>
                </article>
              </li>
            ))}
          </ul>
        </section>
      )}

      <div class="cta-inline">
        <h2>Kostenlose Anfrage — Praxis Mikrostomart in Opole</h2>
        <p>
          Diese Inhalte ersetzen keine Beratung. Senden Sie uns Ihre Frage oder
          Röntgenbilder — Sie erhalten eine unverbindliche Einschätzung und einen
          Kostenvoranschlag auf Deutsch. Behandlung bei Dr. Marcin Nowosielski, M.Sc. RWTH Aachen.
        </p>
        <a class="btn-primary" href={`mailto:${site.clinic.email}`}>Anfrage senden →</a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post { max-width: 48rem; }
  .breadcrumbs { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1.5rem; }
  .breadcrumbs a { text-decoration: none; }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs .current { color: var(--color-fg); }

  .post header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  .post h1 { font-size: 2.25rem; margin: 1rem 0; }
  .lead { font-size: 1.1875rem; color: var(--color-muted); }
  .post-meta { font-size: 0.75rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 0; display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
  .post-meta a { text-decoration: none; }
  .category { color: var(--color-accent); font-weight: 700; }

  .author-card { background: var(--color-card); padding: 1.25rem; border-left: 3px solid var(--color-accent); border-radius: 4px; margin-top: 1.5rem; }
  .author-card strong { display: block; }
  .author-card p { margin: 0.25rem 0 0; color: var(--color-muted); font-size: 0.9375rem; }

  .prose :global(h2) { margin-top: 2.5rem; }
  .prose :global(h3) { margin-top: 1.5rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
    margin: 1.5rem 0;
    background: var(--color-card);
    border-radius: 4px;
  }
  .prose :global(table) { border-collapse: collapse; width: 100%; margin: 1.5rem 0; font-size: 0.9375rem; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--color-border); padding: 0.625rem 0.875rem; text-align: left; }
  .prose :global(th) { background: var(--color-primary); color: white; }
  .prose :global(code) { background: var(--color-bg); padding: 0.125rem 0.375rem; font-size: 0.9em; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; display: block; }
  .prose :global(figure) { margin: 1.5rem 0; }
  .prose :global(figcaption) { font-size: 0.8125rem; color: var(--color-muted); text-align: center; margin-top: 0.5rem; font-style: italic; }

  .post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .tag { background: var(--color-bg); padding: 0.375rem 0.75rem; font-size: 0.8125rem; color: var(--color-muted); text-decoration: none; border-radius: 3px; }
  .tag:hover { background: var(--color-accent); color: white; }

  .related { margin-bottom: 3rem; }
  .related h2 { font-size: 1.375rem; margin-bottom: 1rem; }
  .related ul { list-style: none; padding: 0; display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .related li { background: var(--color-card); padding: 1.25rem; border-left: 3px solid var(--color-accent); border-radius: 4px; }
  .related h3 { font-size: 1rem; margin: 0.375rem 0; }
  .related h3 a { text-decoration: none; }
  .related h3 a:hover { text-decoration: underline; }
  .related p { font-size: 0.875rem; color: var(--color-muted); margin: 0; }
  .related-meta { font-size: 0.6875rem !important; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 !important; display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .cta-inline { background: var(--color-primary); color: white; padding: 2rem; border-radius: 8px; text-align: center; }
  .cta-inline h2 { color: var(--color-accent); margin-top: 0; }
  .cta-inline p { color: #d4ddd6; }
</style>

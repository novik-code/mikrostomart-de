---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categoryMeta, formatDate, slugify } from '../../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tagSlugMap = new Map<string, string>();
  posts.forEach((p) => { p.data.tags.forEach((t) => tagSlugMap.set(slugify(t), t)); });
  return Array.from(tagSlugMap.entries()).map(([slug, originalTag]) => ({
    params: { tag: slug },
    props: {
      tag: originalTag,
      posts: posts.filter((p) => p.data.tags.some((t) => slugify(t) === slug)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { posts, tag } = Astro.props as { posts: Awaited<ReturnType<typeof getCollection<'blog'>>>; tag: string };
const displayTag = tag.replace(/-/g, ' ');
---

<BaseLayout noindex={true} title={`#${displayTag} — Artikel`} description={`Artikel mit Tag #${displayTag} — mikrostomart.de`}>
  <div class="container content">
    <nav class="breadcrumbs"><a href="/">Start</a> · <a href="/blog">Blog</a> · <span>#{displayTag}</span></nav>
    <header>
      <p class="eyebrow">Tag</p>
      <h1>#{displayTag}</h1>
      <p class="meta">{posts.length} 'Artikel'</p>
    </header>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <article>
            <p class="post-meta">
              <span class="category">{categoryMeta[post.data.category]?.label ?? post.data.category}</span>
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </p>
            <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <a class="read-more" href={`/blog/${post.id}`}>Weiterlesen →</a>
          </article>
        </li>
      ))}
    </ul>
    <p class="see-all-link"><a href="/blog">← Alle Artikel</a></p>
  </div>
</BaseLayout>

<style>
  .content { max-width: 56rem; }
  .breadcrumbs { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 1.5rem; }
  .breadcrumbs a { text-decoration: none; }
  header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .meta { font-size: 0.8125rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.75rem; color: var(--color-accent); margin: 0 0 0.5rem; font-weight: 700; }
  .post-list { list-style: none; padding: 0; }
  .post-list > li { background: var(--color-card); padding: 1.75rem; border-radius: 6px; border-left: 3px solid var(--color-accent); margin-bottom: 1.25rem; }
  .post-list h2 { margin: 0.5rem 0 0.75rem; }
  .post-list h2 a { text-decoration: none; }
  .post-meta { font-size: 0.75rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
  .category { color: var(--color-accent); font-weight: 700; }
  .read-more { font-weight: 600; text-decoration: none; }
  .see-all-link { margin-top: 2rem; text-align: center; }
  .see-all-link a { font-weight: 600; }
</style>
